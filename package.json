{
  "name": "tamaclaudie",
  "version": "0.1.0",
  "description": "A Tamagotchi you raise in your terminal: a deterministic Node body and a Claude Code soul.",
  "type": "module",
  "bin": {
    "tama": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "tama": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
